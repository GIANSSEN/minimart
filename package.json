{
  "name": "minimart-electron",
  "version": "1.0.0",
  "private": true,
  "description": "Minimart Laravel Electron App",
  "main": "main.js",
  "type": "commonjs",

  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "electron .",
    "electron-build": "electron-builder"
  },

  "devDependencies": {
    "axios": "^1.1.2",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "laravel-vite-plugin": "^0.8.0",
    "vite": "^4.0.0"
  },

  "dependencies": {
    "bootstrap": "^5.3.0",
    "chart.js": "^4.4.0",
    "jquery": "^3.7.0",
    "sweetalert2": "^11.7.0"
  },

  "build": {
    "appId": "com.minimart.app",
    "productName": "CJ's Minimart",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "public/images/logo-cjs.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}